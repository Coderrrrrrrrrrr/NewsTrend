# --- AI Model Config ---
# Specify your LLM provider's base URL and API Key
# For example, OpenAI, Gemini (via Google AI Studio), DeepSeek, etc.
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o  # or gemini-1.5-flash, deepseek-chat, etc.

# --- Database Config ---
DATABASE_URL=sqlite:///./data/news_trend.db

# --- Crawler / RSS Config ---
# Optional: RSSHub instance URL
RSSHUB_URL=https://rsshub.app

# --- Other Config ---
SCRAPE_INTERVAL_HOURS=1
ADMIN_PASSWORD=admin123  # For basic UI access control
